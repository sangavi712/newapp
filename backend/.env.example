# BuddyLearn AI - Backend Environment Variables

# MongoDB connection string (Required for cross-device sync)
# For local MongoDB: mongodb://localhost:27017/buddylearn
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/buddylearn

# MongoDB database name
MONGODB_DB=buddylearn

# Frontend Client URL for CORS (Required for cross-device requests)
# For local development: http://localhost:3000
# For production: https://<your-frontend-app-name>.vercel.app
# Multiple origins can be comma-separated: http://localhost:3000,https://my-app.vercel.app
CLIENT_URL=http://localhost:3000

# Secret key for JWT authentication (Change in production!)
JWT_SECRET_KEY=dev-secret-key-change-in-prod

# OpenAI API Key for AI Buddy features
OPENAI_API_KEY=your_openai_api_key_here

# (Optional) Local SQLite Database URL override
# DATABASE_URL=sqlite:///buddylearn.db
